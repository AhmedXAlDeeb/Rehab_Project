<mujoco model="rehab_arm">
    <compiler autolimits="true" coordinate="local"/>
    <option gravity="0 0 -9.81" timestep="0.01" />

    <worldbody>
        <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>
        <geom type="plane" size="2 2 0.1" rgba=".9 .9 .9 1"/>
        
        <!-- Target Point (Mocap allows us to move it easily) -->
        <body name="target" pos="0.4 0 0.5" mocap="true">
            <geom type="sphere" size="0.03" rgba="0 1 0 0.5" contype="0" conaffinity="0"/>
        </body>

        <!-- Robotic Arm Base -->
        <body name="base" pos="0 0 0.5">
            <geom type="cylinder" size="0.05 0.1" rgba="0.2 0.2 0.2 1"/>
            <body name="upper_arm" pos="0 0 0.1">
                <joint name="shoulder" type="hinge" axis="0 1 0" range="-90 90"/>
                <geom name="upper_arm_geom" type="capsule" size="0.03" fromto="0 0 0 0 0 0.3" rgba="0.7 0.7 0.7 1"/>
                
                <body name="forearm" pos="0 0 0.3">
                    <joint name="elbow" type="hinge" axis="0 1 0" range="0 150"/>
                    <geom name="forearm_geom" type="capsule" size="0.025" fromto="0 0 0 0 0 0.25" rgba="0.5 0.5 0.5 1"/>
                    <site name="fingertip" pos="0 0 0.25" size="0.01"/>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <!-- Motor torques -->
        <motor joint="shoulder" ctrlrange="-20 20" gear="1"/>
        <motor joint="elbow" ctrlrange="-20 20" gear="1"/>
    </actuator>
</mujoco>